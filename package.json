{
  "name": "denote",
  "version": "0.1.5",
  "description": "Desktop-first local AI knowledge tool.",
  "private": true,
  "type": "module",
  "main": "src/main/main.cjs",
  "author": "Dennis",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis:x64",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.denote.desktop",
    "productName": "Denote",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/renderer/**/*",
      "src/ask/**/*",
      "src/cards/**/*",
      "src/chunking/**/*",
      "src/retrieval/**/*",
      "src/samples/**/*",
      "src/settings/**/*",
      "src/storage/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
