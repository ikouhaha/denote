{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Denote",
  "version": "0.1.8",
  "identifier": "com.denote.desktop",
  "build": {
    "frontendDist": "../src/renderer",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Denote",
        "width": 1220,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
